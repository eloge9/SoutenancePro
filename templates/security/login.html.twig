{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body_class %}login-page{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-box">

        <div class="login-logo">
            <a href="{{ path('public_soutenances') }}">
                <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro">
            </a>
        </div>

        <div class="login-title">
            <h2>Connexion</h2>
            <p>Accédez à votre espace de gestion des soutenances</p>
        </div>

        {% if error %}
            <div class="flash-error mb-3">
                <i class="fa fa-exclamation-circle mr-2"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="flash-success mb-3">
                Vous êtes connecté en tant que {{ app.user.userIdentifier }}.
                <a href="{{ path('app_logout') }}">Se déconnecter</a>
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">

            <div class="form-group">
                <label for="inputEmail">
                    <i class="fa fa-envelope mr-1"></i> Adresse e-mail
                </label>
                <input type="email"
                       value="{{ last_username }}"
                       name="email"
                       id="inputEmail"
                       autocomplete="email"
                       required
                       autofocus
                       placeholder="votre@email.com">
            </div>

            <div class="form-group">
                <label for="inputPassword">
                    <i class="fa fa-lock mr-1"></i> Mot de passe
                </label>
                <input type="password"
                       name="password"
                       id="inputPassword"
                       autocomplete="current-password"
                       required
                       placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group" style="display:flex; align-items:center; gap:8px;">
                <input type="checkbox" name="_remember_me" id="rememberMe" style="width:auto; margin:0;">
                <label for="rememberMe" style="margin:0; font-weight:400; font-size:13px;">Se souvenir de moi</label>
            </div>

            <button type="submit" class="login-btn">
                <i class="fa fa-sign-in mr-2"></i> Se connecter
            </button>
        </form>

        <div class="login-footer">
            <a href="{{ path('public_soutenances') }}" style="color: #6c5ffc; text-decoration: none;">
                <i class="fa fa-eye mr-1"></i> Voir les soutenances publiques
            </a>
        </div>
    </div>
</div>
{% endblock %}
