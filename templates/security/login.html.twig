{% extends 'base.html.twig' %}

{% block title %}Connexion — SoutenancePro{% endblock %}

{% block stylesheets %}
<style>
body { background: #f7f8fc; }
.login-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 15px; }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper" style="padding-left:0; background:#f7f8fc; min-height:100vh;">

    <!-- Preloader -->
    <div class="preloader"></div>

    <div class="login-wrapper">
        <div class="signup-section" style="width:100%; max-width:480px; padding:0;">
            <div class="inner-container">

                <!-- Logo -->
                <div class="logo" style="text-align:center; margin-bottom:30px;">
                    <a href="{{ path('public_soutenances') }}">
                        <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro" style="height:55px;">
                    </a>
                </div>

                <h2>Connexion</h2>
                <div class="text">Accédez à votre espace de gestion des soutenances</div>

                <!-- Error -->
                {% if error %}
                    <div class="alert alert-danger" style="border-radius:5px; margin-bottom:20px; font-size:14px;">
                        <i class="fa fa-exclamation-circle" style="margin-right:6px;"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <!-- Form -->
                <form method="post" action="{{ path('app_login') }}">
                    <div class="styled-form">

                        <div class="form-group">
                            <label for="inputEmail">Adresse e-mail</label>
                            <input type="email"
                                   value="{{ last_username }}"
                                   name="email"
                                   id="inputEmail"
                                   autocomplete="email"
                                   required
                                   autofocus
                                   placeholder="votre@email.com">
                        </div>

                        <div class="form-group">
                            <label for="inputPassword">Mot de passe</label>
                            <input type="password"
                                   name="password"
                                   id="inputPassword"
                                   autocomplete="current-password"
                                   required
                                   placeholder="••••••••">
                            <span class="eye-icon fa fa-eye-slash"></span>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="form-group" style="text-align:center;">
                            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 60px; border:none; cursor:pointer;">
                                <span class="txt">Se connecter</span>
                            </button>
                        </div>

                        <div class="form-group users" style="margin-bottom:0;">
                            <a href="{{ path('public_soutenances') }}" style="font-size:13px;">
                                <i class="fa fa-calendar" style="margin-right:5px;"></i>Voir les soutenances publiques
                            </a>
                        </div>

                    </div>
                </form>

            </div>
            <!-- Copyright -->
            <div class="copyright" style="margin-top:25px;">
                &copy; {{ "now"|date("Y") }} SoutenancePro
            </div>
        </div>
    </div>

</div>
{% endblock %}
