{% extends 'base.html.twig' %}

{% block title %}Soutenances publiques — SoutenancePro{% endblock %}

{% block stylesheets %}
<style>
.setting-form .form-group input[type="date"] {
    position:relative;display:block;width:100%;line-height:28px;
    padding:10px 25px;color:#888;border:1px solid transparent;
    height:46px;font-size:14px;border-radius:50px;background:#f5fbff;
    transition:all 300ms ease;
}
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper" style="padding-left:0;">

    <!-- Preloader -->
    <div class="preloader"></div>

    <!-- Main Header (public) -->
    <header class="main-header">
        <div class="header-upper">
            <div class="auto-container">
                <div class="clearfix">
                    <div class="header-left clearfix">
                        <div class="pull-left logo-box" style="margin-left:0;">
                            <div class="logo" style="padding:13px 0;">
                                <a href="{{ path('public_soutenances') }}">
                                    <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro" style="height:42px;">
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="header-right clearfix">
                        <div class="options-box clearfix" style="padding:15px 0;">
                            <a href="{{ path('app_login') }}" class="theme-btn btn-style-one" style="padding:8px 25px;font-size:13px;">
                                <span class="txt"><i class="fa fa-sign-in" style="margin-right:5px;"></i>Connexion</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <!-- End Main Header -->

    <!-- Page Banner -->
    <div style="background:linear-gradient(135deg,#ff5773 0%,#ff9066 100%);padding:50px 0;text-align:center;color:#fff;">
        <div class="auto-container">
            <h3 style="color:#fff;font-weight:700;margin-bottom:10px;">Soutenances de fin d'études</h3>
            <p style="color:rgba(255,255,255,.85);font-size:15px;margin:0;">Consultez le calendrier des soutenances universitaires</p>
        </div>
    </div>

    <!-- Content -->
    <div class="sidebar-page-container" style="padding:50px 0;">
        <div class="auto-container">

            <!-- Search -->
            <div class="sidebar-widget" style="margin-bottom:25px;">
                <div class="widget-content" style="padding:20px 25px;">
                    <form method="get" action="{{ path('public_soutenances') }}" class="clearfix">
                        <div class="pull-left" style="width:calc(100% - 130px);padding-right:15px;">
                            <div class="setting-form">
                                <div class="form-group" style="margin:0;">
                                    <input type="date" name="date" value="{{ dateSearch }}"
                                           style="width:100%;height:44px;padding:0 20px;border:1px solid #e8e8e8;border-radius:50px;font-size:13px;background:#f8f9fd;outline:none;">
                                </div>
                            </div>
                        </div>
                        <div class="pull-left" style="padding-top:2px;">
                            <button type="submit" class="theme-btn btn-style-one" style="padding:9px 25px;font-size:13px;border:none;cursor:pointer;">
                                <span class="txt"><i class="fa fa-search" style="margin-right:5px;"></i>Filtrer</span>
                            </button>
                            {% if dateSearch %}
                                <a href="{{ path('public_soutenances') }}" style="margin-left:10px;color:#71718a;font-size:13px;">Tout voir</a>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>

            <!-- Results -->
            {% if soutenances|length > 0 %}

            {% if dateSearch %}
            <p style="color:#71718a;font-size:13px;margin-bottom:20px;">
                <i class="fa fa-calendar" style="margin-right:5px;color:#ff5773;"></i>
                {{ soutenances|length }} soutenance(s) le {{ dateSearch|date('d/m/Y') }}
            </p>
            {% endif %}

            <div class="row clearfix">
                {% for soutenance in soutenances %}
                <div class="col-lg-6 col-md-12" style="margin-bottom:25px;">
                    <div class="sidebar-widget" style="margin:0;">
                        <div class="widget-content" style="padding:0;border-radius:8px;overflow:hidden;">

                            <!-- Card Header -->
                            <div style="background:linear-gradient(135deg,#ff5773,#ff9066);padding:18px 22px;color:#fff;">
                                <div class="clearfix">
                                    <div class="pull-left">
                                        <div style="font-size:20px;font-weight:700;">{{ soutenance.date|date('d') }}</div>
                                        <div style="font-size:13px;opacity:.9;">{{ soutenance.date|date('M Y') }}</div>
                                    </div>
                                    <div class="pull-right" style="text-align:right;">
                                        <div style="font-size:22px;font-weight:700;">{{ soutenance.heure|date('H:i') }}</div>
                                        {% if soutenance.salle %}
                                        <div style="font-size:13px;font-weight:600;opacity:1;">
                                            <i class="flaticon-location" style="margin-right:3px;"></i>
                                            {{ soutenance.salle.nom }}
                                        </div>
                                        <div style="font-size:11px;opacity:.8;margin-top:2px;">
                                            {{ soutenance.salle.localisation }}
                                        </div>
                                        {% else %}
                                        <div style="font-size:13px;opacity:.9;">—</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div style="padding:20px 22px;">
                                {% if soutenance.etudiant %}
                                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:5px;">
                                    {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}
                                </h6>
                                <div style="margin-bottom:10px;">
                                    <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                        {{ soutenance.etudiant.filiere }}
                                    </span>
                                </div>
                                <p style="font-size:13px;color:#555;line-height:1.5;margin-bottom:15px;">
                                    <i class="fa fa-book" style="color:#ff5773;margin-right:5px;"></i>
                                    {{ soutenance.etudiant.themeMemoire }}
                                </p>
                                {% endif %}

                                <!-- Jury -->
                                <div style="border-top:1px solid #f0f0f0;padding-top:12px;">
                                    <div style="font-size:11px;text-transform:uppercase;color:#aaa;font-weight:700;letter-spacing:1px;margin-bottom:10px;">Jury</div>
                                    <div style="font-size:12px;">
                                        {% if soutenance.president %}
                                        <div style="margin-bottom:4px;color:#555;">
                                            <span style="display:inline-block;width:80px;color:#ff5773;font-weight:600;">Président</span>
                                            {{ soutenance.president.prenom }} {{ soutenance.president.nom }}
                                        </div>
                                        {% endif %}
                                        {% if soutenance.examinateur %}
                                        <div style="margin-bottom:4px;color:#555;">
                                            <span style="display:inline-block;width:80px;color:#ff9066;font-weight:600;">Examinateur</span>
                                            {{ soutenance.examinateur.prenom }} {{ soutenance.examinateur.nom }}
                                        </div>
                                        {% endif %}
                                        {% if soutenance.encadreur %}
                                        <div style="color:#555;">
                                            <span style="display:inline-block;width:80px;color:#d4a017;font-weight:600;">Encadreur</span>
                                            {{ soutenance.encadreur.prenom }} {{ soutenance.encadreur.nom }}
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            {% else %}
            <div style="text-align:center;padding:60px 20px;color:#71718a;">
                <span class="flaticon-schedule" style="font-size:60px;color:#e0e0e0;display:block;margin-bottom:20px;"></span>
                {% if dateSearch %}
                    <h5 style="color:#555;margin-bottom:10px;">Aucune soutenance ce jour</h5>
                    <p>Il n'y a pas de soutenance programmée le {{ dateSearch|date('d/m/Y') }}.</p>
                    <a href="{{ path('public_soutenances') }}" class="theme-btn btn-style-one" style="margin-top:15px;display:inline-block;">
                        <span class="txt">Voir toutes les soutenances</span>
                    </a>
                {% else %}
                    <h5 style="color:#555;margin-bottom:10px;">Aucune soutenance programmée</h5>
                    <p>Le calendrier des soutenances n'est pas encore disponible.</p>
                {% endif %}
            </div>
            {% endif %}

        </div>
    </div>

    <!-- Footer -->
    <footer class="main-footer" style="background:#fff;border-top:1px solid #f0f0f0;padding:20px 0;margin-top:20px;">
        <div class="auto-container">
            <div style="text-align:center;color:#aaa;font-size:13px;">
                <img src="{{ asset('logo/logo_court.png') }}" alt="SoutenancePro" style="height:30px;vertical-align:middle;margin-right:8px;opacity:.5;">
                &copy; {{ "now"|date("Y") }} SoutenancePro &mdash; Gestion des soutenances universitaires
            </div>
        </div>
    </footer>

</div>
<!-- End page-wrapper -->
{% endblock %}
