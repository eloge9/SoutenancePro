{% extends 'base.html.twig' %}

{% block title %}Soutenances publiques{% endblock %}

{% block body_class %}public-page{% endblock %}

{% block body %}

<!-- En-tête public -->
<header class="public-header">
    <div style="display:flex; align-items:center;">
        <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro"
             style="height: 48px; margin-right: 15px;">
        <span style="color:#fff; font-size:18px; font-weight:700; letter-spacing:0.3px;">
            SoutenancePro
        </span>
    </div>
    <a href="{{ path('app_login') }}"
       style="background: #6c5ffc; color:#fff; padding: 8px 20px; border-radius: 6px; text-decoration:none; font-size:14px; font-weight:600;">
        <i class="fa fa-sign-in mr-2"></i> Connexion
    </a>
</header>

<!-- Hero Banner -->
<div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%); padding: 50px 30px; text-align: center;">
    <h1 style="color:#fff; font-size: 32px; font-weight: 800; margin: 0 0 12px;">
        Calendrier des Soutenances
    </h1>
    <p style="color: rgba(255,255,255,0.7); font-size: 16px; margin: 0;">
        Consultez les soutenances de fin d'études programmées
    </p>

    <!-- Statistiques rapides -->
    <div style="display:flex; justify-content:center; gap:30px; margin-top:30px; flex-wrap:wrap;">
        <div style="background:rgba(255,255,255,0.08); border-radius:10px; padding:15px 25px; color:#fff;">
            <div style="font-size:28px; font-weight:800;">{{ soutenances|length }}</div>
            <div style="font-size:12px; opacity:0.7; margin-top:2px;">Soutenance(s) programmée(s)</div>
        </div>
    </div>
</div>

<!-- Recherche par date -->
<div style="background: rgba(255,255,255,0.05); padding: 20px 30px; border-top: 1px solid rgba(255,255,255,0.08);">
    <form method="get" action="{{ path('public_soutenances') }}"
          style="max-width: 420px; margin: 0 auto; display:flex; gap:10px;">
        <input type="date" name="date" value="{{ dateSearch }}"
               style="flex:1; padding: 10px 14px; border:none; border-radius: 8px; font-size:14px;">
        <button type="submit"
                style="background:#6c5ffc; color:#fff; border:none; padding: 10px 20px; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer;">
            <i class="fa fa-search"></i> Filtrer
        </button>
        {% if dateSearch %}
            <a href="{{ path('public_soutenances') }}"
               style="background:rgba(255,255,255,0.2); color:#fff; padding: 10px 16px; border-radius:8px; text-decoration:none; font-size:14px;">
                <i class="fa fa-times"></i>
            </a>
        {% endif %}
    </form>
</div>

<!-- Contenu principal -->
<div style="max-width: 1200px; margin: 0 auto; padding: 30px 20px;">

    {% if soutenances|length > 0 %}

        <!-- Filtre par date (visuel) -->
        <div style="margin-bottom: 25px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;">
            <h2 style="font-size: 20px; font-weight: 700; color: #2c3e50; margin:0;">
                <i class="fa fa-calendar mr-2" style="color:#6c5ffc;"></i>
                Toutes les soutenances
            </h2>
            <div style="font-size:13px; color:#888;">
                Dernière mise à jour : {{ "now"|date('d/m/Y à H:i') }}
            </div>
        </div>

        <!-- Grille des soutenances -->
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px;">
            {% for soutenance in soutenances %}
                <div style="background:#fff; border-radius:12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08);
                            overflow:hidden; transition: transform 0.2s, box-shadow 0.2s;"
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 25px rgba(0,0,0,0.12)';"
                     onmouseout="this.style.transform=''; this.style.boxShadow='0 2px 12px rgba(0,0,0,0.08)';">

                    <!-- Entête de la carte : Date -->
                    <div style="background: linear-gradient(135deg, #6c5ffc, #5a4ee0); padding: 15px 20px; color:#fff;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <div style="font-size:22px; font-weight:800; line-height:1;">
                                    {{ soutenance.date|date('d') }}
                                </div>
                                <div style="font-size:13px; opacity:0.85; text-transform:uppercase; letter-spacing:1px;">
                                    {{ soutenance.date|date('M Y') }}
                                </div>
                            </div>
                            <div style="text-align:right;">
                                <div style="font-size:20px; font-weight:700;">
                                    {{ soutenance.heure|date('H:i') }}
                                </div>
                                <div style="font-size:12px; opacity:0.8;">
                                    Salle {{ soutenance.salle.code }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Corps de la carte -->
                    <div style="padding: 18px 20px;">

                        <!-- Étudiant -->
                        <div style="margin-bottom:12px;">
                            <div style="font-size:16px; font-weight:700; color:#2c3e50;">
                                {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}
                            </div>
                            <div style="font-size:12px; color:#888; margin-top:2px;">
                                <i class="fa fa-graduation-cap mr-1"></i> {{ soutenance.etudiant.filiere }}
                            </div>
                        </div>

                        <!-- Thème -->
                        <div style="background:#f8f9fe; border-radius:6px; padding:10px 12px; margin-bottom:14px;">
                            <div style="font-size:11px; color:#6c5ffc; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:4px;">
                                Thème du mémoire
                            </div>
                            <div style="font-size:13px; color:#444; font-style:italic; line-height:1.4;">
                                "{{ soutenance.etudiant.themeMemoire }}"
                            </div>
                        </div>

                        <!-- Lieu -->
                        <div style="font-size:13px; color:#666; margin-bottom:12px;">
                            <i class="fa fa-map-marker mr-1" style="color:#6c5ffc;"></i>
                            {{ soutenance.salle.localisation }}
                        </div>

                        <!-- Jury -->
                        <div style="border-top: 1px solid #f0f0f8; padding-top: 12px;">
                            <div style="font-size:11px; color:#888; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">
                                Jury
                            </div>
                            <div style="display:flex; flex-direction:column; gap:5px;">
                                <div style="display:flex; align-items:center; gap:8px; font-size:13px;">
                                    <span style="background:rgba(108,95,252,0.1); color:#6c5ffc; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:700; min-width:70px; text-align:center;">
                                        Président
                                    </span>
                                    {{ soutenance.president.nom }} {{ soutenance.president.prenom }}
                                </div>
                                <div style="display:flex; align-items:center; gap:8px; font-size:13px;">
                                    <span style="background:rgba(44,176,255,0.1); color:#2cb0ff; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:700; min-width:70px; text-align:center;">
                                        Examinateur
                                    </span>
                                    {{ soutenance.examinateur.nom }} {{ soutenance.examinateur.prenom }}
                                </div>
                                <div style="display:flex; align-items:center; gap:8px; font-size:13px;">
                                    <span style="background:rgba(46,213,115,0.1); color:#2ed573; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:700; min-width:70px; text-align:center;">
                                        Encadreur
                                    </span>
                                    {{ soutenance.encadreur.nom }} {{ soutenance.encadreur.prenom }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

    {% else %}
        <div style="text-align:center; padding: 80px 20px; color: #aaa;">
            <i class="fa fa-calendar-o" style="font-size:60px; margin-bottom:20px; display:block; opacity:0.3;"></i>
            <h3 style="color: #555; font-weight: 600;">Aucune soutenance programmée</h3>
            <p style="font-size: 15px;">Les soutenances apparaîtront ici une fois planifiées.</p>
        </div>
    {% endif %}
</div>

<!-- Footer public -->
<footer style="background: #1a1a2e; color: rgba(255,255,255,0.6); text-align:center; padding: 20px; font-size:13px; margin-top: 40px;">
    &copy; {{ "now"|date("Y") }} SoutenancePro — Système de gestion des soutenances de fin d'études
    &nbsp;|&nbsp;
    <a href="{{ path('app_login') }}" style="color: #6c5ffc; text-decoration:none;">Espace connecté</a>
</footer>

{% endblock %}
