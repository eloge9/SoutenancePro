<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{% block title %}SoutenancePro{% endblock %}</title>
    <link rel="shortcut icon" href="{{ asset('akadimia/images/favicon.png') }}" type="image/png">

    <link href="{{ asset('akadimia/css/bootstrap.css') }}" rel="stylesheet">
    <link href="{{ asset('akadimia/css/main.css') }}" rel="stylesheet">
    <link href="{{ asset('akadimia/css/responsive.css') }}" rel="stylesheet">
    <link id="theme-color-file" href="{{ asset('akadimia/css/color-themes/theme-one.css') }}" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">

{% block body %}{% endblock %}

<script src="{{ asset('akadimia/js/jquery.js') }}"></script>
<script src="{{ asset('akadimia/js/popper.min.js') }}"></script>
<script src="{{ asset('akadimia/js/bootstrap.min.js') }}"></script>
<script src="{{ asset('akadimia/js/appear.js') }}"></script>
<script src="{{ asset('akadimia/js/owl.js') }}"></script>
<script src="{{ asset('akadimia/js/wow.js') }}"></script>
<script src="{{ asset('akadimia/js/script.js') }}"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
