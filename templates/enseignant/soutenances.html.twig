{% extends 'base_enseignant.html.twig' %}

{% block title %}Mes soutenances{% endblock %}
{% block page_title %}Mes soutenances{% endblock %}

{% block content %}

<div class="sidebar-widget">
    <div class="widget-content" style="padding:0;">
        {% if soutenances|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover" style="margin:0;font-size:13px;">
                <thead>
                    <tr style="background:#f8f9fd;color:#71718a;font-size:12px;text-transform:uppercase;letter-spacing:.5px;">
                        <th style="padding:15px 20px;">Date &amp; Heure</th>
                        <th>Étudiant</th>
                        <th>Thème</th>
                        <th>Salle</th>
                        <th>Mon rôle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in soutenances %}
                    {% set s = item.soutenance %}
                    <tr>
                        <td style="padding:14px 20px;white-space:nowrap;">
                            <strong>{{ s.date|date('d/m/Y') }}</strong><br>
                            <span style="color:#71718a;font-size:12px;">{{ s.heure|date('H:i') }}</span>
                        </td>
                        <td>
                            {% if s.etudiant %}
                                <strong>{{ s.etudiant.nom }} {{ s.etudiant.prenom }}</strong><br>
                                <span style="font-size:12px;color:#71718a;">{{ s.etudiant.filiere }}</span>
                            {% else %}&mdash;{% endif %}
                        </td>
                        <td style="font-size:12px;color:#777;max-width:200px;">
                            {% if s.etudiant %}
                                {{ s.etudiant.themeMemoire|slice(0,60) }}{% if s.etudiant.themeMemoire|length > 60 %}…{% endif %}
                            {% else %}&mdash;{% endif %}
                        </td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                {{ s.salle ? s.salle.code : '—' }}
                            </span>
                        </td>
                        <td>
                            {% if item.role == 'Président' %}
                                <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:3px 12px;font-size:12px;font-weight:600;">Président</span>
                            {% elseif item.role == 'Examinateur' %}
                                <span style="background:#fff5f0;color:#ff9066;border-radius:20px;padding:3px 12px;font-size:12px;font-weight:600;">Examinateur</span>
                            {% else %}
                                <span style="background:#fffbf0;color:#d4a017;border-radius:20px;padding:3px 12px;font-size:12px;font-weight:600;">Encadreur</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div style="text-align:center;padding:50px;color:#71718a;">
            <span class="flaticon-schedule" style="font-size:48px;color:#e0e0e0;display:block;margin-bottom:15px;"></span>
            <p>Vous n'avez pas encore de soutenance programmée.</p>
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}
