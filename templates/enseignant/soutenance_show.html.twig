{% extends 'base_enseignant.html.twig' %}

{% block title %}Soutenance — {{ soutenance.etudiant ? soutenance.etudiant.nom ~ ' ' ~ soutenance.etudiant.prenom : 'Détail' }}{% endblock %}
{% block page_title %}Détail de la soutenance{% endblock %}

{% block content %}

<div style="margin-bottom:20px;">
    <a href="{{ path('enseignant_soutenances') }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour à mes soutenances
    </a>
</div>

<!-- Mon rôle -->
<div style="margin-bottom:25px;">
    {% if role == 'Président' %}
        <span style="background:#fff0f3;color:#ff5773;border:1px solid #ff5773;border-radius:20px;padding:5px 18px;font-size:13px;font-weight:700;">
            <i class="fa fa-star" style="margin-right:5px;"></i>Mon rôle : Président du jury
        </span>
    {% elseif role == 'Examinateur' %}
        <span style="background:#fff5f0;color:#ff9066;border:1px solid #ff9066;border-radius:20px;padding:5px 18px;font-size:13px;font-weight:700;">
            <i class="fa fa-search" style="margin-right:5px;"></i>Mon rôle : Examinateur
        </span>
    {% else %}
        <span style="background:#fffbf0;color:#d4a017;border:1px solid #d4a017;border-radius:20px;padding:5px 18px;font-size:13px;font-weight:700;">
            <i class="fa fa-book" style="margin-right:5px;"></i>Mon rôle : Encadreur
        </span>
    {% endif %}
</div>

<div class="row clearfix">

    <!-- Colonne gauche : étudiant + mémoire -->
    <div class="col-lg-6 col-md-12">

        <!-- Étudiant -->
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-student" style="color:#ff5773;margin-right:8px;"></i>Étudiant
                </h6>
                {% if soutenance.etudiant %}
                <table style="width:100%;font-size:13px;line-height:2.2;">
                    <tr>
                        <td style="color:#71718a;width:38%;">Nom complet</td>
                        <td><strong>{{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Filière</td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                {{ soutenance.etudiant.filiere }}
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;vertical-align:top;padding-top:6px;">Thème</td>
                        <td style="font-size:13px;color:#555;line-height:1.6;">{{ soutenance.etudiant.themeMemoire }}</td>
                    </tr>
                </table>
                {% else %}
                <p style="color:#aaa;">Aucun étudiant associé.</p>
                {% endif %}
            </div>
        </div>

        <!-- Mémoire -->
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-book" style="color:#ff5773;margin-right:8px;"></i>Mémoire
                </h6>
                {% if soutenance.etudiant and soutenance.etudiant.fichierMemoire %}
                <p style="font-size:13px;color:#555;margin-bottom:18px;">
                    Le mémoire de l'étudiant est disponible au téléchargement.
                </p>
                <a href="{{ asset('uploads/memoires/' ~ soutenance.etudiant.fichierMemoire) }}"
                   target="_blank"
                   class="theme-btn btn-style-one"
                   style="padding:10px 28px;font-size:13px;display:inline-block;">
                    <span class="txt">
                        <i class="fa fa-download" style="margin-right:6px;"></i>Télécharger le mémoire (PDF)
                    </span>
                </a>
                {% else %}
                <div style="text-align:center;padding:20px 0;color:#aaa;">
                    <i class="fa fa-file-o" style="font-size:36px;display:block;margin-bottom:10px;color:#e0e0e0;"></i>
                    <p style="font-size:13px;">Aucun fichier mémoire déposé.</p>
                </div>
                {% endif %}
            </div>
        </div>

    </div>

    <!-- Colonne droite : soutenance + jury -->
    <div class="col-lg-6 col-md-12">

        <!-- Informations soutenance -->
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-schedule" style="color:#ff5773;margin-right:8px;"></i>Informations pratiques
                </h6>
                <table style="width:100%;font-size:13px;line-height:2.4;">
                    <tr>
                        <td style="color:#71718a;width:38%;">Date</td>
                        <td>
                            <strong style="color:#0f0e2d;">{{ soutenance.date|date('l d F Y')|capitalize }}</strong>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Heure</td>
                        <td>
                            <strong style="color:#0f0e2d;">{{ soutenance.heure|date('H:i') }}</strong>
                        </td>
                    </tr>
                    {% if soutenance.salle %}
                    <tr>
                        <td style="color:#71718a;">Salle</td>
                        <td><strong>{{ soutenance.salle.nom }}</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Localisation</td>
                        <td style="color:#555;">
                            <i class="flaticon-location" style="color:#ff5773;margin-right:4px;font-size:12px;"></i>
                            {{ soutenance.salle.localisation }}
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Capacité</td>
                        <td style="color:#555;">{{ soutenance.salle.capacite }} places</td>
                    </tr>
                    {% endif %}
                </table>
            </div>
        </div>

        <!-- Jury -->
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-instructor" style="color:#ff5773;margin-right:8px;"></i>Composition du jury
                </h6>

                {% if soutenance.president %}
                <div style="display:flex;align-items:center;margin-bottom:14px;padding:10px 14px;background:#fff0f3;border-radius:8px;border-left:3px solid #ff5773;">
                    <div style="width:36px;height:36px;border-radius:50%;background:#ff5773;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;margin-right:12px;">
                        {{ soutenance.president.prenom|first|upper }}
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:13px;color:#0f0e2d;">{{ soutenance.president.prenom }} {{ soutenance.president.nom }}</div>
                        <div style="font-size:11px;color:#ff5773;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Président</div>
                        <div style="font-size:12px;color:#71718a;">{{ soutenance.president.specialite }}</div>
                    </div>
                </div>
                {% endif %}

                {% if soutenance.examinateur %}
                <div style="display:flex;align-items:center;margin-bottom:14px;padding:10px 14px;background:#fff5f0;border-radius:8px;border-left:3px solid #ff9066;">
                    <div style="width:36px;height:36px;border-radius:50%;background:#ff9066;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;margin-right:12px;">
                        {{ soutenance.examinateur.prenom|first|upper }}
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:13px;color:#0f0e2d;">{{ soutenance.examinateur.prenom }} {{ soutenance.examinateur.nom }}</div>
                        <div style="font-size:11px;color:#ff9066;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Examinateur</div>
                        <div style="font-size:12px;color:#71718a;">{{ soutenance.examinateur.specialite }}</div>
                    </div>
                </div>
                {% endif %}

                {% if soutenance.encadreur %}
                <div style="display:flex;align-items:center;padding:10px 14px;background:#fffbf0;border-radius:8px;border-left:3px solid #d4a017;">
                    <div style="width:36px;height:36px;border-radius:50%;background:#d4a017;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;margin-right:12px;">
                        {{ soutenance.encadreur.prenom|first|upper }}
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:13px;color:#0f0e2d;">{{ soutenance.encadreur.prenom }} {{ soutenance.encadreur.nom }}</div>
                        <div style="font-size:11px;color:#d4a017;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Encadreur</div>
                        <div style="font-size:12px;color:#71718a;">{{ soutenance.encadreur.specialite }}</div>
                    </div>
                </div>
                {% endif %}

            </div>
        </div>

    </div>
</div>

{% endblock %}
