{% extends 'base_enseignant.html.twig' %}

{% block title %}Mes jurys{% endblock %}
{% block page_title %}Mes jurys{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h2>Mes jurys</h2>
        <div class="breadcrumb-custom">
            <a href="{{ path('enseignant_dashboard') }}">Accueil</a> › Mes jurys
        </div>
    </div>
</div>

<!-- Président -->
{% if soutenancesPresident is defined and soutenancesPresident|length > 0 %}
<div class="table-card" style="margin-bottom: 25px;">
    <div class="table-card-header" style="border-left: 4px solid #6c5ffc;">
        <h5>
            <span class="badge-role badge-president" style="margin-right: 8px;">Président</span>
            Soutenances où je suis Président du jury
            <span style="color:#888; font-weight:400; font-size:13px;">({{ soutenancesPresident|length }})</span>
        </h5>
    </div>
    <div class="table-card-body">
        <table class="table-soutenance">
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Filière</th>
                    <th>Thème</th>
                    <th>Date & Heure</th>
                    <th>Salle</th>
                    <th>Examinateur</th>
                    <th>Encadreur</th>
                </tr>
            </thead>
            <tbody>
                {% for s in soutenancesPresident %}
                    <tr>
                        <td><strong>{{ s.etudiant.nom }} {{ s.etudiant.prenom }}</strong></td>
                        <td>{{ s.etudiant.filiere }}</td>
                        <td style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                            title="{{ s.etudiant.themeMemoire }}">{{ s.etudiant.themeMemoire }}</td>
                        <td>{{ s.date|date('d/m/Y') }} <span style="color:#888;">{{ s.heure|date('H:i') }}</span></td>
                        <td><span style="font-family:monospace; color:#6c5ffc; font-weight:600;">{{ s.salle.code }}</span></td>
                        <td>{{ s.examinateur.nom }} {{ s.examinateur.prenom }}</td>
                        <td>{{ s.encadreur.nom }} {{ s.encadreur.prenom }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<!-- Examinateur -->
