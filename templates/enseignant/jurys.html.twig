{% extends 'base_enseignant.html.twig' %}

{% block title %}Mes jurys{% endblock %}
{% block page_title %}Mes participations aux jurys{% endblock %}

{% block content %}

{% macro jury_table(soutenances, role, colorStyle) %}
    {% if soutenances|length > 0 %}
    <div class="table-responsive">
        <table class="table table-hover" style="margin:0;font-size:13px;">
            <thead>
                <tr style="background:#f8f9fd;color:#71718a;font-size:12px;">
                    <th style="padding:12px 20px;">Date</th>
                    <th>Heure</th>
                    <th>Étudiant</th>
                    <th>Thème</th>
                    <th>Salle</th>
                </tr>
            </thead>
            <tbody>
                {% for s in soutenances %}
                <tr>
                    <td style="padding:12px 20px;"><strong>{{ s.date|date('d/m/Y') }}</strong></td>
                    <td>{{ s.heure|date('H:i') }}</td>
                    <td>{{ s.etudiant ? s.etudiant.nom ~ ' ' ~ s.etudiant.prenom : '—' }}</td>
                    <td style="font-size:12px;color:#777;max-width:180px;">
                        {% if s.etudiant %}
                            {{ s.etudiant.themeMemoire|slice(0,55) }}{% if s.etudiant.themeMemoire|length > 55 %}…{% endif %}
                        {% else %}&mdash;{% endif %}
                    </td>
                    <td>{{ s.salle ? s.salle.code : '—' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="padding:25px 20px;color:#aaa;font-size:13px;text-align:center;">
        Aucune participation en tant que {{ role|lower }}.
    </div>
    {% endif %}
{% endmacro %}

<!-- Président -->
<div class="sidebar-widget" style="margin-bottom:20px;">
    <div class="widget-content" style="padding:0;">
        <div style="padding:18px 25px;background:#fff0f3;border-radius:5px 5px 0 0;border-left:4px solid #ff5773;">
            <h6 style="margin:0;color:#ff5773;font-weight:700;font-size:14px;">
                <i class="fa fa-star" style="margin-right:8px;"></i>Président du jury
                <span style="background:#ff5773;color:#fff;border-radius:20px;padding:2px 10px;font-size:12px;margin-left:8px;">{{ soutenancesPresident|length }}</span>
            </h6>
        </div>
        {{ _self.jury_table(soutenancesPresident, 'Président', '#ff5773') }}
    </div>
</div>

<!-- Examinateur -->
<div class="sidebar-widget" style="margin-bottom:20px;">
    <div class="widget-content" style="padding:0;">
        <div style="padding:18px 25px;background:#fff5f0;border-radius:5px 5px 0 0;border-left:4px solid #ff9066;">
            <h6 style="margin:0;color:#ff9066;font-weight:700;font-size:14px;">
                <i class="fa fa-user" style="margin-right:8px;"></i>Examinateur
                <span style="background:#ff9066;color:#fff;border-radius:20px;padding:2px 10px;font-size:12px;margin-left:8px;">{{ soutenancesExaminateur|length }}</span>
            </h6>
        </div>
        {{ _self.jury_table(soutenancesExaminateur, 'Examinateur', '#ff9066') }}
    </div>
</div>

<!-- Encadreur -->
<div class="sidebar-widget">
    <div class="widget-content" style="padding:0;">
        <div style="padding:18px 25px;background:#fffbf0;border-radius:5px 5px 0 0;border-left:4px solid #f0c142;">
            <h6 style="margin:0;color:#d4a017;font-weight:700;font-size:14px;">
                <i class="fa fa-graduation-cap" style="margin-right:8px;"></i>Encadreur
                <span style="background:#f0c142;color:#fff;border-radius:20px;padding:2px 10px;font-size:12px;margin-left:8px;">{{ soutenancesEncadreur|length }}</span>
            </h6>
        </div>
        {{ _self.jury_table(soutenancesEncadreur, 'Encadreur', '#f0c142') }}
    </div>
</div>

{% endblock %}
