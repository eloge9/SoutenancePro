        </table>
    </div>
</div>
{% endif %}

<!-- Encadreur -->
{% if soutenancesEncadreur is defined and soutenancesEncadreur|length > 0 %}
<div class="table-card">
    <div class="table-card-header" style="border-left: 4px solid #2ed573;">
