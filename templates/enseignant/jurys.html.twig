                        <td>{{ s.date|date('d/m/Y') }} <span style="color:#888;">{{ s.heure|date('H:i') }}</span></td>
                        <td><span style="font-family:monospace; color:#6c5ffc; font-weight:600;">{{ s.salle.code }}</span></td>
                        <td>{{ s.president.nom }} {{ s.president.prenom }}</td>
                        <td>{{ s.examinateur.nom }} {{ s.examinateur.prenom }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if (soutenancesPresident is not defined or soutenancesPresident|length == 0)
    and (soutenancesExaminateur is not defined or soutenancesExaminateur|length == 0)
    and (soutenancesEncadreur is not defined or soutenancesEncadreur|length == 0) %}
    <div class="table-card">
        <div class="table-card-body">
            <div style="padding: 40px; text-align: center; color: #aaa;">
                <i class="flaticon-test" style="font-size:40px; margin-bottom:12px; display:block; opacity:0.4;"></i>
                <p>Vous n'avez aucune participation à un jury pour le moment.</p>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
