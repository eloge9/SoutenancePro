{% extends 'base_enseignant.html.twig' %}

{% block title %}Mon tableau de bord{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h2>
            Bonjour,
            {% if app.user and app.user.enseignant %}
                {{ app.user.enseignant.prenom }} {{ app.user.enseignant.nom }}
            {% else %}
                {{ app.user.email }}
            {% endif %}
        </h2>
        <div class="breadcrumb-custom">Espace Enseignant</div>
    </div>
</div>

<!-- Statistiques -->
<div class="stat-cards">
    <div class="stat-card">
        <div class="stat-icon purple">
            <span class="fa fa-calendar"></span>
        </div>
        <div class="stat-info">
            <h3>{{ nbSoutenances }}</h3>
            <p>Mes soutenances</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon blue">
            <span class="fa fa-gavel"></span>
        </div>
        <div class="stat-info">
            <h3>{{ nbJurys }}</h3>
            <p>Participations jury</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon green">
            <span class="fa fa-users"></span>
        </div>
        <div class="stat-info">
            <h3>{{ nbEtudiants }}</h3>
            <p>Étudiants concernés</p>
        </div>
    </div>
</div>

<!-- Prochaines soutenances -->
<div class="table-card">
    <div class="table-card-header">
        <h5><i class="fa fa-clock-o mr-2"></i> Prochaines soutenances</h5>
        <a href="{{ path('enseignant_soutenances') }}" class="btn-action btn-view">Voir tout</a>
    </div>
    <div class="table-card-body">
        {% if soutenances is defined and soutenances|length > 0 %}
            <table class="table-soutenance">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Thème</th>
                        <th>Date & Heure</th>
                        <th>Salle</th>
                        <th>Mon rôle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in soutenances %}
                        <tr>
                            <td>
                                <strong>{{ item.soutenance.etudiant.nom }} {{ item.soutenance.etudiant.prenom }}</strong>
                                <div style="font-size:12px; color:#888;">{{ item.soutenance.etudiant.filiere }}</div>
                            </td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                title="{{ item.soutenance.etudiant.themeMemoire }}">
                                {{ item.soutenance.etudiant.themeMemoire }}
                            </td>
                            <td>
                                <div style="font-weight:600;">{{ item.soutenance.date|date('d/m/Y') }}</div>
                                <div style="color:#888; font-size:12px;">{{ item.soutenance.heure|date('H:i') }}</div>
                            </td>
                            <td>
                                <span style="font-family:monospace; color:#6c5ffc; font-weight:600;">
                                    {{ item.soutenance.salle.code }}
                                </span>
                            </td>
                            <td>
                                <span class="badge-role badge-{{ item.role|lower }}">
                                    {{ item.role }}
                                </span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div style="padding: 30px; text-align: center; color: #aaa;">
                <i class="fa fa-calendar-o" style="font-size:32px; margin-bottom:10px; display:block;"></i>
                Aucune soutenance à venir pour le moment.
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
