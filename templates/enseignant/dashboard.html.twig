{% extends 'base_enseignant.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block content %}

<!-- Stat Cards -->
<div class="dashboard-section">
    <div class="row clearfix">

        <div class="dashboard-block col-lg-4 col-md-6 col-sm-12">
            <a href="{{ path('enseignant_soutenances') }}" style="text-decoration:none;color:inherit;">
                <div class="inner-box">
                    <div class="content">
                        <div class="icon-box"><span class="flaticon-schedule"></span></div>
                        <div class="courses">Mes soutenances<span>{{ nbSoutenances }}</span></div>
                    </div>
                </div>
            </a>
        </div>

        <div class="dashboard-block col-lg-4 col-md-6 col-sm-12">
            <a href="{{ path('enseignant_jurys') }}" style="text-decoration:none;color:inherit;">
                <div class="inner-box">
                    <div class="content">
                        <div class="icon-box"><span class="flaticon-file"></span></div>
                        <div class="courses">Participations jury<span>{{ nbJurys }}</span></div>
                    </div>
                </div>
            </a>
        </div>

        <div class="dashboard-block col-lg-4 col-md-6 col-sm-12">
            <div class="inner-box">
                <div class="content">
                    <div class="icon-box"><span class="flaticon-student"></span></div>
                    <div class="courses">Étudiants encadrés<span>{{ nbEtudiants }}</span></div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Recent Soutenances -->
{% if soutenances|length > 0 %}
<div class="sidebar-widget" style="margin-top:10px;">
    <div class="widget-content" style="padding:25px 30px;">
        <div class="clearfix" style="margin-bottom:20px;">
            <div class="pull-left">
                <h6 style="color:#0f0e2d;font-weight:700;margin:0;">Mes prochaines soutenances</h6>
            </div>
            <div class="pull-right">
                <a href="{{ path('enseignant_soutenances') }}" class="see-all">Voir tout</a>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover" style="margin:0;font-size:13px;">
                <thead>
                    <tr style="background:#f8f9fd;color:#71718a;">
                        <th>Date</th>
                        <th>Heure</th>
                        <th>Étudiant</th>
                        <th>Salle</th>
                        <th>Mon rôle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in soutenances|slice(0, 5) %}
                    {% set s = item.soutenance %}
                    <tr>
                        <td><strong>{{ s.date|date('d/m/Y') }}</strong></td>
                        <td>{{ s.heure|date('H:i') }}</td>
                        <td>{{ s.etudiant ? s.etudiant.nom ~ ' ' ~ s.etudiant.prenom : '—' }}</td>
                        <td>{{ s.salle ? s.salle.code : '—' }}</td>
                        <td>
                            {% if item.role == 'Président' %}
                                <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">Président</span>
                            {% elseif item.role == 'Examinateur' %}
                                <span style="background:#fff5f0;color:#ff9066;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">Examinateur</span>
                            {% else %}
                                <span style="background:#fffbf0;color:#d4a017;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">Encadreur</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="sidebar-widget" style="margin-top:10px;">
    <div class="widget-content" style="padding:40px;text-align:center;color:#71718a;">
        <span class="flaticon-schedule" style="font-size:40px;color:#e0e0e0;display:block;margin-bottom:10px;"></span>
        <p>Vous n'avez pas encore de soutenance programmée.</p>
    </div>
</div>
{% endif %}

{% endblock %}
