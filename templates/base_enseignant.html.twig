{% extends 'base.html.twig' %}

{% block body %}
<div class="page-wrapper">

    <!-- Preloader -->
    <div class="preloader"></div>

    <!-- Main Header -->
    <header class="main-header">
        <div class="header-upper">
            <div class="outer-container">
                <div class="clearfix">

                    <div class="header-left clearfix">
                        <div class="left-sidebar-btn hidden-bar-opener">
                            <span class="icon flaticon-menu-2"></span>
                        </div>
                        <div class="pull-left logo-box">
                            <div class="logo">
                                <a href="{{ path('enseignant_dashboard') }}">
                                    <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro" style="height:42px; margin-top:14px;">
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="header-right clearfix">
                        <div class="options-box clearfix">
                            <div class="profile-box dropdown" id="someElementID5">
                                <div class="btn btn-default dropdown-toggle" data-toggle="dropdown">
                                    <span class="profile-image" style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:#ff5773;color:#fff;font-weight:700;font-size:15px;vertical-align:middle;">
                                        {{ app.user ? app.user.email|first|upper : 'E' }}
                                    </span>
                                    <i class="arrow flaticon-down-arrow" style="margin-left:6px;"></i>
                                </div>
                                <div class="profile-content">
                                    <div class="setting" style="padding:10px 15px;font-weight:600;color:#0f0e2d;font-size:13px;border-bottom:1px solid #f0f0f0;">
                                        {% if app.user and app.user.enseignant %}
                                            {{ app.user.enseignant.prenom }} {{ app.user.enseignant.nom }}
                                        {% else %}
                                            {{ app.user ? app.user.email : 'Enseignant' }}
                                        {% endif %}
                                    </div>
                                    <ul class="pages" style="margin:0;padding:5px 0;">
                                        <li><a href="{{ path('app_logout') }}"><i class="fa fa-sign-out" style="margin-right:6px;"></i>Déconnexion</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </header>
    <!-- End Main Header -->

    <!-- Page Content -->
    <div class="sidebar-page-container">
        <div class="auto-container">

            <!-- Page Title -->
            <div class="sec-title" style="margin-bottom:25px;">
                <div class="clearfix">
                    <div class="pull-left">
                        <h4 style="color:#0f0e2d;font-weight:700;">{% block page_title %}Espace Enseignant{% endblock %}</h4>
                    </div>
                </div>
            </div>

            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert" style="border-radius:5px;margin-bottom:20px;">
                        <i class="fa fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}" style="margin-right:8px;"></i>
                        {{ message }}
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Content Block -->
            {% block content %}{% endblock %}

        </div>
    </div>
    <!-- End Page Content -->

</div>
<!-- End page-wrapper -->

<!-- Sidebar Nav (sidenav-list) -->
<div class="sidenav-list">
    <ul class="navbar">
        <li>
            <a href="{{ path('enseignant_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'enseignant_dashboard' ? 'active' : '' }}">
                <i class="icon flaticon-home"></i>
                <span><i class="flaticon-home"></i> Tableau de bord</span>
            </a>
        </li>
        <li>
            <a href="{{ path('enseignant_soutenances') }}" class="{{ app.request.attributes.get('_route') == 'enseignant_soutenances' ? 'active' : '' }}">
                <i class="icon flaticon-schedule"></i>
                <span><i class="flaticon-schedule"></i> Mes soutenances</span>
            </a>
        </li>
        <li>
            <a href="{{ path('enseignant_jurys') }}" class="{{ app.request.attributes.get('_route') == 'enseignant_jurys' ? 'active' : '' }}">
                <i class="icon flaticon-file"></i>
                <span><i class="flaticon-file"></i> Mes jurys</span>
            </a>
        </li>
        <li>
            <a href="{{ path('app_logout') }}">
                <i class="icon fa fa-sign-out"></i>
                <span><i class="fa fa-sign-out"></i> Déconnexion</span>
            </a>
        </li>
    </ul>
</div>
<!-- End Sidebar Nav -->

<!-- Hidden Navigation Bar -->
<section class="hidden-bar left-align">
    <div class="color-layer"></div>
    <div class="hidden-bar-closer">
        <span class="flaticon-multiply"></span>
    </div>
    <div class="hidden-bar-wrapper">
        <ul class="pages-list">
            <li class="{{ app.request.attributes.get('_route') == 'enseignant_dashboard' ? 'active' : '' }}">
                <a href="{{ path('enseignant_dashboard') }}">
                    <span class="icon flaticon-home"></span>Tableau de bord
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') == 'enseignant_soutenances' ? 'active' : '' }}">
                <a href="{{ path('enseignant_soutenances') }}">
                    <span class="icon flaticon-schedule"></span>Mes soutenances
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') == 'enseignant_jurys' ? 'active' : '' }}">
                <a href="{{ path('enseignant_jurys') }}">
                    <span class="icon flaticon-file"></span>Mes jurys
                </a>
            </li>
        </ul>
        <div class="heading">Compte</div>
        <ul class="pages-list">
            <li>
                <a href="{{ path('app_logout') }}">
                    <span class="icon fa fa-sign-out"></span>Déconnexion
                </a>
            </li>
        </ul>
    </div>
    <div class="copyright-text">&copy; {{ "now"|date("Y") }} SoutenancePro</div>
</section>
<!-- End Hidden Navigation Bar -->

{% block javascripts %}{{ parent() }}{% endblock %}

<script>
(function () {
    var box = document.getElementById('someElementID5');
    if (!box) return;
    var toggle = box.querySelector('.dropdown-toggle');
    toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        box.classList.toggle('dropdown-active');
    });
    document.addEventListener('click', function (e) {
        if (!box.contains(e.target)) {
            box.classList.remove('dropdown-active');
        }
    });
})();
</script>
{% endblock %}
