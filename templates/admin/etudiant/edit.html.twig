{% extends 'base_admin.html.twig' %}

{% block title %}Modifier l'étudiant{% endblock %}
{% block page_title %}Étudiants{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h2>Modifier : {{ etudiant.nom }} {{ etudiant.prenom }}</h2>
        <div class="breadcrumb-custom">
            <a href="{{ path('admin_dashboard') }}">Accueil</a> ›
            <a href="{{ path('admin_etudiant_index') }}">Étudiants</a> ›
            Modifier
        </div>
    </div>
    <div style="display:flex; gap:10px;">
        <a href="{{ path('admin_etudiant_show', {id: etudiant.id}) }}" class="btn-secondary-custom">
            <i class="fa fa-eye"></i> Voir
        </a>
        <a href="{{ path('admin_etudiant_index') }}" class="btn-secondary-custom">
            <i class="fa fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="form-card">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.nom, 'Nom') }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.prenom, 'Prénom') }}
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.prenom) }}
            </div>
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.email, 'Adresse e-mail') }}
        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.email) }}
    </div>

    <div class="form-group">
        {{ form_label(form.filiere, 'Filière') }}
        {{ form_widget(form.filiere, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.filiere) }}
    </div>

    <div class="form-group">
        {{ form_label(form.themeMemoire, 'Thème du mémoire') }}
        {{ form_widget(form.themeMemoire, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.themeMemoire) }}
    </div>

    {% if form.fichierMemoire is defined %}
    <div class="form-group">
        {{ form_label(form.fichierMemoire, 'Fichier du mémoire (PDF)') }}
        {% if etudiant.fichierMemoire %}
            <div style="margin-bottom: 8px; font-size: 13px; color: #666;">
                <i class="fa fa-file-pdf-o"></i> Fichier actuel : {{ etudiant.fichierMemoire }}
            </div>
        {% endif %}
        {{ form_widget(form.fichierMemoire, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.fichierMemoire) }}
    </div>
    {% endif %}

    <div class="form-actions">
        <button type="submit" class="btn-primary-custom">
            <i class="fa fa-save"></i> Enregistrer les modifications
        </button>
        <a href="{{ path('admin_etudiant_index') }}" class="btn-secondary-custom">
            <i class="fa fa-times"></i> Annuler
        </a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
