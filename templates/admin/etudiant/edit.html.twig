{% extends 'base_admin.html.twig' %}

{% block title %}Modifier {{ etudiant.nom }} {{ etudiant.prenom }}{% endblock %}
{% block page_title %}Modifier l'étudiant{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_etudiant_show', {id: etudiant.id}) }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour au profil
    </a>
{% endblock %}

{% block stylesheets %}
<style>
.setting-form .form-group input[type="date"],
.setting-form .form-group input[type="time"],
.setting-form .form-group input[type="file"] {
    position:relative;display:block;width:100%;line-height:28px;
    padding:10px 25px;color:#888;border:1px solid transparent;
    height:46px;font-size:14px;border-radius:50px;background:#f5fbff;
    transition:all 300ms ease;font-family:'Roboto',sans-serif;
}
</style>
{% endblock %}

{% block content %}

<div class="sidebar-widget">
    <div class="widget-content" style="padding:30px 35px;">
        <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid #f0f0f0;">
            <i class="flaticon-student" style="color:#ff5773;margin-right:8px;"></i>
            {{ etudiant.nom }} {{ etudiant.prenom }}
        </h6>

        {{ form_start(form, {'attr': {'class': 'setting-form', 'enctype': 'multipart/form-data'}}) }}

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.nom, 'Nom') }}
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.prenom, 'Prénom') }}
                    {{ form_widget(form.prenom) }}
                    {{ form_errors(form.prenom) }}
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.email, 'Adresse e-mail') }}
                    {{ form_widget(form.email) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.filiere, 'Filière') }}
                    {{ form_widget(form.filiere) }}
                    {{ form_errors(form.filiere) }}
                </div>
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.themeMemoire, 'Thème du mémoire') }}
            {{ form_widget(form.themeMemoire) }}
            {{ form_errors(form.themeMemoire) }}
        </div>

        <div class="form-group">
            {{ form_label(form.fichierMemoire, 'Remplacer le fichier PDF (optionnel)') }}
            {% if etudiant.fichierMemoire %}
                <div style="margin-bottom:8px;font-size:13px;color:#71718a;">
                    <i class="fa fa-file-pdf-o" style="color:#ff5773;margin-right:5px;"></i>
                    Fichier actuel :
                    <a href="{{ asset('uploads/memoires/' ~ etudiant.fichierMemoire) }}" target="_blank" style="color:#ff5773;">
                        {{ etudiant.fichierMemoire }}
                    </a>
                </div>
            {% endif %}
            {{ form_widget(form.fichierMemoire) }}
            {{ form_errors(form.fichierMemoire) }}
        </div>

        <div class="form-group" style="margin-top:10px;">
            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 40px;border:none;cursor:pointer;">
                <span class="txt"><i class="fa fa-save" style="margin-right:5px;"></i>Enregistrer</span>
            </button>
            <a href="{{ path('admin_etudiant_show', {id: etudiant.id}) }}" class="theme-btn btn-style-two" style="padding:10px 30px;margin-left:10px;">
                <span class="txt">Annuler</span>
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
