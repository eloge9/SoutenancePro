{% extends 'base_admin.html.twig' %}

{% block title %}Étudiants{% endblock %}
{% block page_title %}Gestion des étudiants{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_etudiant_new') }}" class="theme-btn btn-style-one" style="padding:8px 20px;font-size:13px;">
        <span class="txt"><i class="fa fa-plus" style="margin-right:5px;"></i>Ajouter un étudiant</span>
    </a>
{% endblock %}

{% block content %}

<!-- Search -->
<div class="sidebar-widget" style="margin-bottom:20px;">
    <div class="widget-content" style="padding:20px 25px;">
        <form method="get" action="{{ path('admin_etudiant_index') }}" class="clearfix">
            <div class="pull-left" style="width:calc(100% - 120px); padding-right:15px;">
                <input type="text" name="q" value="{{ search }}" placeholder="Rechercher par nom, prénom ou e-mail…"
                       style="width:100%;height:44px;padding:0 15px;border:1px solid #e8e8e8;border-radius:50px;font-size:13px;background:#f8f9fd;outline:none;">
            </div>
            <div class="pull-left">
                <button type="submit" class="theme-btn btn-style-one" style="padding:9px 25px;font-size:13px;border:none;cursor:pointer;">
                    <span class="txt"><i class="fa fa-search" style="margin-right:5px;"></i>Rechercher</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- List -->
<div class="sidebar-widget">
    <div class="widget-content" style="padding:0;">
        {% if etudiants|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover" style="margin:0;font-size:13px;">
                <thead>
                    <tr style="background:#f8f9fd;color:#71718a;font-size:12px;text-transform:uppercase;letter-spacing:.5px;">
                        <th style="padding:15px 20px;">Nom complet</th>
                        <th>E-mail</th>
                        <th>Filière</th>
                        <th>Thème de mémoire</th>
                        <th>Mémoire</th>
                        <th style="text-align:right;padding-right:20px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for etudiant in etudiants %}
                    <tr>
                        <td style="padding:14px 20px;">
                            <strong>{{ etudiant.nom }} {{ etudiant.prenom }}</strong>
                        </td>
                        <td style="color:#71718a;">{{ etudiant.email }}</td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:3px 10px;font-size:12px;font-weight:600;">
                                {{ etudiant.filiere }}
                            </span>
                        </td>
                        <td style="color:#777;max-width:200px;">
                            {{ etudiant.themeMemoire|slice(0,50) }}{% if etudiant.themeMemoire|length > 50 %}…{% endif %}
                        </td>
                        <td>
                            {% if etudiant.fichierMemoire %}
                                <a href="{{ asset('uploads/memoires/' ~ etudiant.fichierMemoire) }}" target="_blank" style="color:#ff5773;" title="Télécharger">
                                    <i class="fa fa-file-pdf-o"></i>
                                </a>
                            {% else %}
                                <span style="color:#ccc;" title="Aucun fichier"><i class="fa fa-file-o"></i></span>
                            {% endif %}
                        </td>
                        <td style="text-align:right;padding-right:20px;">
                            <a href="{{ path('admin_etudiant_show', {id: etudiant.id}) }}" title="Voir" style="color:#71718a;margin-right:8px;">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a href="{{ path('admin_etudiant_edit', {id: etudiant.id}) }}" title="Modifier" style="color:#ff9066;margin-right:8px;">
                                <i class="fa fa-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_etudiant_delete', {id: etudiant.id}) }}" style="display:inline;"
                                  onsubmit="return confirm('Supprimer cet étudiant ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etudiant.id) }}">
                                <button type="submit" title="Supprimer" style="background:none;border:none;cursor:pointer;color:#e74c3c;padding:0;">
                                    <i class="fa fa-trash-o"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div style="text-align:center;padding:50px;color:#71718a;">
            <span class="flaticon-student" style="font-size:48px;color:#e0e0e0;display:block;margin-bottom:15px;"></span>
            {% if search %}
                <p>Aucun étudiant trouvé pour « {{ search }} ».</p>
                <a href="{{ path('admin_etudiant_index') }}" style="color:#ff5773;">Réinitialiser la recherche</a>
            {% else %}
                <p>Aucun étudiant enregistré.</p>
                <a href="{{ path('admin_etudiant_new') }}" class="theme-btn btn-style-one" style="margin-top:10px;display:inline-block;">
                    <span class="txt">Ajouter le premier étudiant</span>
                </a>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}
