{% extends 'base_admin.html.twig' %}

{% block title %}Nouvelle salle{% endblock %}
{% block page_title %}Ajouter une salle{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_salle_index') }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour à la liste
    </a>
{% endblock %}

{% block content %}

<div class="sidebar-widget">
    <div class="widget-content" style="padding:30px 35px;max-width:600px;">
        <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid #f0f0f0;">
            <i class="flaticon-location" style="color:#ff5773;margin-right:8px;"></i>Informations de la salle
        </h6>

        {{ form_start(form, {'attr': {'class': 'setting-form'}}) }}

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.code, 'Code de la salle') }}
                    {{ form_widget(form.code, {'attr': {'placeholder': 'ex: AMPHI-A, B101…'}}) }}
                    {{ form_errors(form.code) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.capacite, 'Capacité (nombre de places)') }}
                    {{ form_widget(form.capacite, {'attr': {'placeholder': 'ex: 50', 'min': 1}}) }}
                    {{ form_errors(form.capacite) }}
                </div>
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.localisation, 'Localisation / Description') }}
            {{ form_widget(form.localisation, {'attr': {'placeholder': 'ex: Bâtiment A, 2ème étage'}}) }}
            {{ form_errors(form.localisation) }}
        </div>

        <div class="form-group" style="margin-top:10px;">
            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 40px;border:none;cursor:pointer;">
                <span class="txt"><i class="fa fa-save" style="margin-right:5px;"></i>Enregistrer</span>
            </button>
            <a href="{{ path('admin_salle_index') }}" class="theme-btn btn-style-two" style="padding:10px 30px;margin-left:10px;">
                <span class="txt">Annuler</span>
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
