{% extends 'base_admin.html.twig' %}

{% block title %}{{ salle.nom }}{% endblock %}
{% block page_title %}Détail de la salle{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_salle_edit', {id: salle.id}) }}" class="theme-btn btn-style-one" style="padding:7px 18px;font-size:13px;margin-right:8px;">
        <span class="txt"><i class="fa fa-pencil" style="margin-right:4px;"></i>Modifier</span>
    </a>
    <a href="{{ path('admin_salle_index') }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Liste
    </a>
{% endblock %}

{% block content %}

<div class="row clearfix">
    <div class="col-lg-5 col-md-12">
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-location" style="color:#ff5773;margin-right:8px;"></i>Informations
                </h6>
                <table style="width:100%;font-size:13px;line-height:2.5;">
                    <tr>
                        <td style="color:#71718a;width:45%;">Code</td>
                        <td>
                            <span style="background:#f0f4ff;color:#7033ff;border-radius:20px;padding:2px 12px;font-size:13px;font-weight:700;font-family:monospace;">
                                {{ salle.code }}
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Nom</td>
                        <td><strong style="font-size:15px;color:#0f0e2d;">{{ salle.nom }}</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Capacité</td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                {{ salle.capacite }} places
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Localisation</td>
                        <td>{{ salle.localisation }}</td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Soutenances</td>
                        <td>{{ salle.soutenances|length }} au total</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    {% if salle.soutenances|length > 0 %}
    <div class="col-lg-7 col-md-12">
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:15px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-schedule" style="color:#ff5773;margin-right:8px;"></i>Soutenances dans cette salle
                </h6>
                <div class="table-responsive">
                    <table class="table" style="margin:0;font-size:12px;">
                        <thead>
                            <tr style="color:#71718a;">
                                <th>Date</th>
                                <th>Heure</th>
                                <th>Étudiant</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for s in salle.soutenances %}
                            <tr>
                                <td>{{ s.date|date('d/m/Y') }}</td>
                                <td>{{ s.heure|date('H:i') }}</td>
                                <td>{{ s.etudiant ? s.etudiant.nom ~ ' ' ~ s.etudiant.prenom : '—' }}</td>
                                <td>
                                    <a href="{{ path('admin_soutenance_show', {id: s.id}) }}" style="color:#ff5773;">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<div style="margin-top:10px;">
    <form method="post" action="{{ path('admin_salle_delete', {id: salle.id}) }}" style="display:inline;"
          onsubmit="return confirm('Supprimer la salle « {{ salle.nom }} » ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ salle.id) }}">
        <button type="submit" style="background:none;border:1px solid #e74c3c;color:#e74c3c;padding:7px 18px;border-radius:50px;font-size:13px;cursor:pointer;">
            <i class="fa fa-trash-o" style="margin-right:5px;"></i>Supprimer cette salle
        </button>
    </form>
</div>

{% endblock %}
