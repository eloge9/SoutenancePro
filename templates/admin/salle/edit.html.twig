{% extends 'base_admin.html.twig' %}

{% block title %}Modifier {{ salle.nom }}{% endblock %}
{% block page_title %}Modifier la salle{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_salle_show', {id: salle.id}) }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour au détail
    </a>
{% endblock %}

{% block content %}

<div class="row clearfix">
<div class="col-lg-8 col-md-10 col-sm-12" style="margin:0 auto;float:none;">
<div class="sidebar-widget">
    <div class="widget-content" style="padding:30px 35px;">
        <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:5px;padding-bottom:15px;border-bottom:1px solid #f0f0f0;">
            <i class="flaticon-location" style="color:#ff5773;margin-right:8px;"></i>{{ salle.nom }}
        </h6>
        <p style="margin-bottom:20px;">
            <span style="background:#f0f4ff;color:#7033ff;border-radius:20px;padding:2px 12px;font-size:12px;font-weight:700;font-family:monospace;">
                {{ salle.code }}
            </span>
            <span style="color:#aaa;font-size:12px;margin-left:8px;">Code généré automatiquement — non modifiable</span>
        </p>

        {{ form_start(form, {'attr': {'class': 'setting-form'}}) }}

        <div class="form-group">
            {{ form_label(form.nom, 'Nom de la salle') }}
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.capacite, 'Capacité (nombre de places)') }}
            {{ form_widget(form.capacite, {'attr': {'min': 1}}) }}
            {{ form_errors(form.capacite) }}
        </div>

        <div class="form-group">
            {{ form_label(form.localisation, 'Localisation') }}
            {{ form_widget(form.localisation) }}
            {{ form_errors(form.localisation) }}
        </div>

        <div class="form-group" style="margin-top:10px;">
            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 40px;border:none;cursor:pointer;">
                <span class="txt"><i class="fa fa-save" style="margin-right:5px;"></i>Enregistrer</span>
            </button>
            <a href="{{ path('admin_salle_show', {id: salle.id}) }}" class="theme-btn btn-style-two" style="padding:10px 30px;margin-left:10px;">
                <span class="txt">Annuler</span>
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
</div>
</div>

{% endblock %}
