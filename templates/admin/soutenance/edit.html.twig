{% extends 'base_admin.html.twig' %}

{% block title %}Modifier la soutenance{% endblock %}
{% block page_title %}Soutenances{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h2>Modifier la soutenance de {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</h2>
        <div class="breadcrumb-custom">
            <a href="{{ path('admin_dashboard') }}">Accueil</a> ›
            <a href="{{ path('admin_soutenance_index') }}">Soutenances</a> ›
            Modifier
        </div>
    </div>
    <div style="display:flex; gap:10px;">
        <a href="{{ path('admin_soutenance_show', {id: soutenance.id}) }}" class="btn-secondary-custom">
            <i class="fa fa-eye"></i> Voir
        </a>
        <a href="{{ path('admin_soutenance_index') }}" class="btn-secondary-custom">
            <i class="fa fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="form-card" style="max-width: 800px;">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    <div class="form-group">
        {{ form_label(form.etudiant, 'Étudiant') }}
        {{ form_widget(form.etudiant, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.etudiant) }}
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.date, 'Date de soutenance') }}
                {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.date) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.heure, 'Heure de début') }}
                {{ form_widget(form.heure, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heure) }}
            </div>
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.salle, 'Salle') }}
        {{ form_widget(form.salle, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.salle) }}
    </div>

    <div style="margin: 20px 0 10px; padding: 12px 0 5px; border-top: 1px solid #f0f0f8;">
        <strong style="color: #555; font-size: 14px;">
            <i class="fa fa-users mr-2"></i> Composition du jury
        </strong>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                {{ form_label(form.president, 'Président') }}
                {{ form_widget(form.president, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.president) }}
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                {{ form_label(form.examinateur, 'Examinateur') }}
                {{ form_widget(form.examinateur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.examinateur) }}
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                {{ form_label(form.encadreur, 'Encadreur') }}
                {{ form_widget(form.encadreur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.encadreur) }}
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary-custom">
            <i class="fa fa-save"></i> Enregistrer les modifications
        </button>
        <a href="{{ path('admin_soutenance_index') }}" class="btn-secondary-custom">
            <i class="fa fa-times"></i> Annuler
        </a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
