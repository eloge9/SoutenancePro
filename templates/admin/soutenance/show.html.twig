{% extends 'base_admin.html.twig' %}

{% block title %}Soutenance de {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}{% endblock %}
{% block page_title %}Soutenances{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h2>Soutenance : {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</h2>
        <div class="breadcrumb-custom">
            <a href="{{ path('admin_dashboard') }}">Accueil</a> ›
            <a href="{{ path('admin_soutenance_index') }}">Soutenances</a> ›
            Détail
        </div>
    </div>
    <div style="display:flex; gap:10px;">
        <a href="{{ path('admin_soutenance_edit', {id: soutenance.id}) }}" class="btn-primary-custom">
            <i class="fa fa-pencil"></i> Modifier
        </a>
        <a href="{{ path('admin_soutenance_index') }}" class="btn-secondary-custom">
            <i class="fa fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<!-- Infos principales -->
<div class="row">
    <div class="col-md-8">
        <div class="detail-card" style="margin-bottom: 20px;">
            <div style="font-weight: 700; color: #555; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 15px;">
                <i class="fa fa-info-circle mr-2" style="color: #6c5ffc;"></i> Informations générales
            </div>

            <div class="detail-row">
                <div class="detail-label">Étudiant</div>
                <div class="detail-value">
                    <strong>{{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</strong>
                    <div style="font-size: 12px; color: #888; margin-top: 2px;">
                        {{ soutenance.etudiant.filiere }} — {{ soutenance.etudiant.email }}
                    </div>
                </div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Thème du mémoire</div>
                <div class="detail-value">{{ soutenance.etudiant.themeMemoire }}</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Date</div>
                <div class="detail-value">{{ soutenance.date|date('d/m/Y') }}</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Heure</div>
                <div class="detail-value">{{ soutenance.heure|date('H:i') }}</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Salle</div>
                <div class="detail-value">
                    <span style="font-family: monospace; font-size: 16px; font-weight: 700; color: #6c5ffc;">
                        {{ soutenance.salle.code }}
                    </span>
                    <span style="color: #888; font-size: 12px; margin-left: 8px;">
                        — {{ soutenance.salle.localisation }} ({{ soutenance.salle.capacite }} places)
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Composition du Jury -->
        <div class="detail-card">
            <div style="font-weight: 700; color: #555; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 15px;">
                <i class="fa fa-users mr-2" style="color: #6c5ffc;"></i> Jury
            </div>

            <div style="margin-bottom: 15px; padding: 12px; background: rgba(108,95,252,0.08); border-radius: 8px; border-left: 3px solid #6c5ffc;">
                <div style="font-size: 11px; color: #6c5ffc; font-weight: 700; text-transform: uppercase; margin-bottom: 4px;">Président</div>
                <div style="font-weight: 600; color: #333;">
                    {{ soutenance.president.nom }} {{ soutenance.president.prenom }}
                </div>
                <div style="font-size: 12px; color: #888;">{{ soutenance.president.specialite }}</div>
            </div>

            <div style="margin-bottom: 15px; padding: 12px; background: rgba(44,176,255,0.08); border-radius: 8px; border-left: 3px solid #2cb0ff;">
                <div style="font-size: 11px; color: #2cb0ff; font-weight: 700; text-transform: uppercase; margin-bottom: 4px;">Examinateur</div>
                <div style="font-weight: 600; color: #333;">
                    {{ soutenance.examinateur.nom }} {{ soutenance.examinateur.prenom }}
                </div>
                <div style="font-size: 12px; color: #888;">{{ soutenance.examinateur.specialite }}</div>
            </div>

            <div style="padding: 12px; background: rgba(46,213,115,0.08); border-radius: 8px; border-left: 3px solid #2ed573;">
                <div style="font-size: 11px; color: #2ed573; font-weight: 700; text-transform: uppercase; margin-bottom: 4px;">Encadreur</div>
                <div style="font-weight: 600; color: #333;">
                    {{ soutenance.encadreur.nom }} {{ soutenance.encadreur.prenom }}
                </div>
                <div style="font-size: 12px; color: #888;">{{ soutenance.encadreur.specialite }}</div>
            </div>
        </div>
    </div>
</div>

<div style="margin-top: 10px;">
    <form method="post" action="{{ path('admin_soutenance_delete', {id: soutenance.id}) }}"
          onsubmit="return confirm('Supprimer cette soutenance ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ soutenance.id) }}">
        <button type="submit" class="btn-danger-custom">
            <i class="fa fa-trash mr-1"></i> Supprimer cette soutenance
        </button>
    </form>
</div>
{% endblock %}
