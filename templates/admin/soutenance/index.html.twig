{% extends 'base_admin.html.twig' %}

{% block title %}Soutenances{% endblock %}
{% block page_title %}Gestion des soutenances{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_soutenance_new') }}" class="theme-btn btn-style-one" style="padding:8px 20px;font-size:13px;">
        <span class="txt"><i class="fa fa-plus" style="margin-right:5px;"></i>Programmer une soutenance</span>
    </a>
{% endblock %}

{% block stylesheets %}
<style>
.setting-form .form-group input[type="date"] {
    position:relative;display:block;width:100%;line-height:28px;
    padding:10px 25px;color:#888;border:1px solid transparent;
    height:46px;font-size:14px;border-radius:50px;background:#f5fbff;
    transition:all 300ms ease;font-family:'Roboto',sans-serif;
}
</style>
{% endblock %}

{% block content %}

<!-- Search -->
<div class="sidebar-widget" style="margin-bottom:20px;">
    <div class="widget-content" style="padding:20px 25px;">
        <form method="get" action="{{ path('admin_soutenance_index') }}" class="clearfix">
            <div class="pull-left" style="width:calc(100% - 120px);padding-right:15px;">
                <div class="setting-form">
                    <div class="form-group" style="margin:0;">
                        <input type="date" name="date" value="{{ dateSearch }}"
                               style="width:100%;height:44px;padding:0 15px;border:1px solid #e8e8e8;border-radius:50px;font-size:13px;background:#f8f9fd;outline:none;">
                    </div>
                </div>
            </div>
            <div class="pull-left" style="padding-top:2px;">
                <button type="submit" class="theme-btn btn-style-one" style="padding:9px 25px;font-size:13px;border:none;cursor:pointer;">
                    <span class="txt"><i class="fa fa-search" style="margin-right:5px;"></i>Filtrer</span>
                </button>
                {% if dateSearch %}
                    <a href="{{ path('admin_soutenance_index') }}" style="margin-left:10px;color:#71718a;font-size:13px;">Effacer</a>
                {% endif %}
            </div>
        </form>
    </div>
</div>

<!-- List -->
<div class="sidebar-widget">
    <div class="widget-content" style="padding:0;">
        {% if soutenances|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover" style="margin:0;font-size:13px;">
                <thead>
                    <tr style="background:#f8f9fd;color:#71718a;font-size:12px;text-transform:uppercase;letter-spacing:.5px;">
                        <th style="padding:15px 20px;">Date &amp; Heure</th>
                        <th>Étudiant</th>
                        <th>Thème</th>
                        <th>Salle</th>
                        <th>Jury</th>
                        <th style="text-align:right;padding-right:20px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for soutenance in soutenances %}
                    <tr>
                        <td style="padding:14px 20px;white-space:nowrap;">
                            <strong>{{ soutenance.date|date('d/m/Y') }}</strong><br>
                            <span style="color:#71718a;font-size:12px;">{{ soutenance.heure|date('H:i') }}</span>
                        </td>
                        <td>
                            {% if soutenance.etudiant %}
                                <strong>{{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</strong><br>
                                <span style="color:#71718a;font-size:12px;">{{ soutenance.etudiant.filiere }}</span>
                            {% else %}&mdash;{% endif %}
                        </td>
                        <td style="max-width:180px;color:#777;font-size:12px;">
                            {% if soutenance.etudiant %}
                                {{ soutenance.etudiant.themeMemoire|slice(0,60) }}{% if soutenance.etudiant.themeMemoire|length > 60 %}…{% endif %}
                            {% else %}&mdash;{% endif %}
                        </td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                {{ soutenance.salle ? soutenance.salle.code : '—' }}
                            </span>
                        </td>
                        <td style="font-size:12px;color:#71718a;">
                            {% if soutenance.president %}<div><i class="fa fa-star" style="color:#ff5773;width:14px;"></i> {{ soutenance.president.nom }}</div>{% endif %}
                            {% if soutenance.examinateur %}<div><i class="fa fa-user" style="color:#ff9066;width:14px;"></i> {{ soutenance.examinateur.nom }}</div>{% endif %}
                            {% if soutenance.encadreur %}<div><i class="fa fa-graduation-cap" style="color:#f0c142;width:14px;"></i> {{ soutenance.encadreur.nom }}</div>{% endif %}
                        </td>
                        <td style="text-align:right;padding-right:20px;white-space:nowrap;">
                            <a href="{{ path('admin_soutenance_show', {id: soutenance.id}) }}" title="Voir" style="color:#71718a;margin-right:8px;">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a href="{{ path('admin_soutenance_edit', {id: soutenance.id}) }}" title="Modifier" style="color:#ff9066;margin-right:8px;">
                                <i class="fa fa-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_soutenance_delete', {id: soutenance.id}) }}" style="display:inline;"
                                  onsubmit="return confirm('Annuler cette soutenance ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ soutenance.id) }}">
                                <button type="submit" title="Annuler" style="background:none;border:none;cursor:pointer;color:#e74c3c;padding:0;">
                                    <i class="fa fa-trash-o"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div style="text-align:center;padding:50px;color:#71718a;">
            <span class="flaticon-schedule" style="font-size:48px;color:#e0e0e0;display:block;margin-bottom:15px;"></span>
            {% if dateSearch %}
                <p>Aucune soutenance trouvée pour le {{ dateSearch|date('d/m/Y') }}.</p>
                <a href="{{ path('admin_soutenance_index') }}" style="color:#ff5773;">Voir toutes les soutenances</a>
            {% else %}
                <p>Aucune soutenance programmée.</p>
                <a href="{{ path('admin_soutenance_new') }}" class="theme-btn btn-style-one" style="margin-top:10px;display:inline-block;">
                    <span class="txt">Programmer la première soutenance</span>
                </a>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}
