{% extends 'base_admin.html.twig' %}

{% block title %}Nouvel enseignant{% endblock %}
{% block page_title %}Ajouter un enseignant{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_enseignant_index') }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour à la liste
    </a>
{% endblock %}

{% block content %}

<div class="sidebar-widget">
    <div class="widget-content" style="padding:30px 35px;">
        <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid #f0f0f0;">
            <i class="flaticon-instructor" style="color:#ff5773;margin-right:8px;"></i>Informations de l'enseignant
        </h6>
        <p style="font-size:13px;color:#71718a;margin-bottom:20px;padding:12px 15px;background:#fff0f3;border-radius:5px;border-left:3px solid #ff5773;">
            <i class="fa fa-info-circle" style="margin-right:6px;color:#ff5773;"></i>
            Un compte utilisateur avec le rôle <strong>ROLE_ENSEIGNANT</strong> sera automatiquement créé avec le mot de passe saisi.
        </p>

        {{ form_start(form, {'attr': {'class': 'setting-form'}}) }}

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.nom, 'Nom') }}
                    {{ form_widget(form.nom, {'attr': {'placeholder': 'Nom de famille'}}) }}
                    {{ form_errors(form.nom) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.prenom, 'Prénom') }}
                    {{ form_widget(form.prenom, {'attr': {'placeholder': 'Prénom'}}) }}
                    {{ form_errors(form.prenom) }}
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.email, 'Adresse e-mail (identifiant de connexion)') }}
                    {{ form_widget(form.email, {'attr': {'placeholder': 'enseignant@universite.fr'}}) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.specialite, 'Spécialité') }}
                    {{ form_widget(form.specialite, {'attr': {'placeholder': 'ex: Informatique, Mathématiques…'}}) }}
                    {{ form_errors(form.specialite) }}
                </div>
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.plainPassword, 'Mot de passe initial') }}
            {{ form_widget(form.plainPassword, {'attr': {'placeholder': 'Mot de passe (min. 6 caractères)'}}) }}
            {{ form_errors(form.plainPassword) }}
            <small style="color:#71718a;font-size:12px;margin-top:5px;display:block;">Ce mot de passe sera communiqué à l'enseignant pour sa première connexion.</small>
        </div>

        <div class="form-group" style="margin-top:10px;">
            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 40px;border:none;cursor:pointer;">
                <span class="txt"><i class="fa fa-save" style="margin-right:5px;"></i>Créer le compte</span>
            </button>
            <a href="{{ path('admin_enseignant_index') }}" class="theme-btn btn-style-two" style="padding:10px 30px;margin-left:10px;">
                <span class="txt">Annuler</span>
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
