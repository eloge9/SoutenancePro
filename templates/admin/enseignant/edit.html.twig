{% extends 'base_admin.html.twig' %}

{% block title %}Modifier {{ enseignant.nom }} {{ enseignant.prenom }}{% endblock %}
{% block page_title %}Modifier l'enseignant{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_enseignant_show', {id: enseignant.id}) }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour au profil
    </a>
{% endblock %}

{% block content %}

<div class="sidebar-widget">
    <div class="widget-content" style="padding:30px 35px;">
        <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid #f0f0f0;">
            <i class="flaticon-instructor" style="color:#ff5773;margin-right:8px;"></i>
            {{ enseignant.nom }} {{ enseignant.prenom }}
        </h6>

        {{ form_start(form, {'attr': {'class': 'setting-form'}}) }}

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.nom, 'Nom') }}
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.prenom, 'Prénom') }}
                    {{ form_widget(form.prenom) }}
                    {{ form_errors(form.prenom) }}
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.email, 'Adresse e-mail') }}
                    {{ form_widget(form.email) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.specialite, 'Spécialité') }}
                    {{ form_widget(form.specialite) }}
                    {{ form_errors(form.specialite) }}
                </div>
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.plainPassword, 'Nouveau mot de passe (laisser vide pour ne pas changer)') }}
            {{ form_widget(form.plainPassword, {'attr': {'placeholder': 'Nouveau mot de passe (optionnel)'}}) }}
            {{ form_errors(form.plainPassword) }}
        </div>

        <div class="form-group" style="margin-top:10px;">
            <button type="submit" class="theme-btn btn-style-one" style="padding:10px 40px;border:none;cursor:pointer;">
                <span class="txt"><i class="fa fa-save" style="margin-right:5px;"></i>Enregistrer</span>
            </button>
            <a href="{{ path('admin_enseignant_show', {id: enseignant.id}) }}" class="theme-btn btn-style-two" style="padding:10px 30px;margin-left:10px;">
                <span class="txt">Annuler</span>
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
