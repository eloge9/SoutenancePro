{% extends 'base_admin.html.twig' %}

{% block title %}{{ enseignant.nom }} {{ enseignant.prenom }}{% endblock %}
{% block page_title %}Profil enseignant{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_enseignant_edit', {id: enseignant.id}) }}" class="theme-btn btn-style-one" style="padding:7px 18px;font-size:13px;margin-right:8px;">
        <span class="txt"><i class="fa fa-pencil" style="margin-right:4px;"></i>Modifier</span>
    </a>
    <a href="{{ path('admin_enseignant_index') }}" style="color:#71718a;font-size:13px;">
        <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Liste
    </a>
{% endblock %}

{% block content %}

<div class="row clearfix">
    <div class="col-lg-6 col-md-12">
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-instructor" style="color:#ff5773;margin-right:8px;"></i>Informations
                </h6>
                <table style="width:100%;font-size:13px;line-height:2.2;">
                    <tr>
                        <td style="color:#71718a;width:40%;">Nom complet</td>
                        <td><strong>{{ enseignant.nom }} {{ enseignant.prenom }}</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">E-mail</td>
                        <td>{{ enseignant.email }}</td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Spécialité</td>
                        <td>
                            <span style="background:#fff0f3;color:#ff5773;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:600;">
                                {{ enseignant.specialite }}
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#71718a;">Compte</td>
                        <td>
                            {% if enseignant.compte %}
                                <span style="color:#27ae60;font-size:12px;"><i class="fa fa-check-circle" style="margin-right:4px;"></i>{{ enseignant.compte.email }}</span>
                            {% else %}
                                <span style="color:#e74c3c;font-size:12px;">Aucun compte associé</span>
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6 col-md-12">
        <div class="sidebar-widget" style="margin-bottom:25px;">
            <div class="widget-content" style="padding:25px 30px;">
                <h6 style="color:#0f0e2d;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f0f0;">
                    <i class="flaticon-schedule" style="color:#ff5773;margin-right:8px;"></i>Jurys
                </h6>
                <div class="row clearfix" style="text-align:center;">
                    <div class="col-4">
                        <div style="font-size:28px;font-weight:700;color:#ff5773;">{{ enseignant.soutenancesPresident|length }}</div>
                        <div style="font-size:12px;color:#71718a;">Présidences</div>
                    </div>
                    <div class="col-4">
                        <div style="font-size:28px;font-weight:700;color:#ff9066;">{{ enseignant.soutenancesExaminateur|length }}</div>
                        <div style="font-size:12px;color:#71718a;">Examens</div>
                    </div>
                    <div class="col-4">
                        <div style="font-size:28px;font-weight:700;color:#f0c142;">{{ enseignant.soutenancesEncadreur|length }}</div>
                        <div style="font-size:12px;color:#71718a;">Encadrements</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete -->
<div style="margin-top:10px;">
    <form method="post" action="{{ path('admin_enseignant_delete', {id: enseignant.id}) }}" style="display:inline;"
          onsubmit="return confirm('Supprimer cet enseignant et son compte utilisateur ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ enseignant.id) }}">
        <button type="submit" style="background:none;border:1px solid #e74c3c;color:#e74c3c;padding:7px 18px;border-radius:50px;font-size:13px;cursor:pointer;">
            <i class="fa fa-trash-o" style="margin-right:5px;"></i>Supprimer cet enseignant
        </button>
    </form>
</div>

{% endblock %}
