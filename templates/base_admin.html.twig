{% extends 'base.html.twig' %}

{% block body_class %}dashboard-body{% endblock %}

{% block body %}
<div class="dashboard-wrapper">

    <!-- ===== SIDEBAR ADMIN ===== -->
    <aside class="dashboard-sidebar" id="adminSidebar">
        <div class="sidebar-logo">
            <a href="{{ path('admin_dashboard') }}">
                <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro">
            </a>
            <div class="app-title">Administration</div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-title">Menu principal</div>
            <ul>
                <li>
                    <a href="{{ path('admin_dashboard') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'admin_dashboard' ? 'active' : '' }}">
                        <span class="nav-icon flaticon-home"></span>
                        <span class="nav-text">Tableau de bord</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_etudiant_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'admin_etudiant' ? 'active' : '' }}">
                        <span class="nav-icon flaticon-student"></span>
                        <span class="nav-text">Étudiants</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_enseignant_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'admin_enseignant' ? 'active' : '' }}">
                        <span class="nav-icon flaticon-instructor"></span>
                        <span class="nav-text">Enseignants</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_salle_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'admin_salle' ? 'active' : '' }}">
                        <span class="nav-icon flaticon-location"></span>
                        <span class="nav-text">Salles</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_soutenance_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'admin_soutenance' ? 'active' : '' }}">
                        <span class="nav-icon flaticon-schedule"></span>
                        <span class="nav-text">Soutenances</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-section-title" style="margin-top: 20px;">Compte</div>
            <ul>
                <li class="nav-logout">
                    <a href="{{ path('app_logout') }}">
                        <span class="nav-icon fa fa-sign-out"></span>
                        <span class="nav-text">Déconnexion</span>
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- ===== MAIN AREA ===== -->
    <div class="dashboard-main">

        <!-- Top Header -->
        <header class="dashboard-header">
            <div class="d-flex align-items-center gap-3">
                <button class="sidebar-toggle" onclick="toggleSidebar()" title="Menu">
                    <i class="fa fa-bars"></i>
                </button>
                <h1 class="page-title mb-0">{% block page_title %}Administration{% endblock %}</h1>
            </div>

            <div class="header-right">
                <div class="user-dropdown dropdown">
                    <button class="btn dropdown-toggle" type="button" data-toggle="dropdown">
                        <div class="user-avatar">
                            {{ app.user ? app.user.email|first|upper : 'A' }}
                        </div>
                        <span>{{ app.user ? app.user.email : 'Admin' }}</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                            <i class="fa fa-sign-out mr-2"></i> Déconnexion
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Flash Messages -->
        <div class="dashboard-content" style="padding-bottom: 0; padding-top: 15px;">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-{{ type == 'success' ? 'success' : 'error' }}">
                        <i class="fa fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }} mr-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <!-- Page Content -->
        <main class="dashboard-content">
            {% block content %}{% endblock %}
        </main>

        <!-- Footer -->
        <footer style="text-align:center; padding: 15px; font-size: 12px; color: #aaa; border-top: 1px solid #f0f0f8; background: #fff;">
            &copy; {{ "now"|date("Y") }} SoutenancePro &mdash; Gestion des soutenances
        </footer>
    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
function toggleSidebar() {
    document.getElementById('adminSidebar').classList.toggle('open');
}
</script>
{% endblock %}
{% endblock %}
