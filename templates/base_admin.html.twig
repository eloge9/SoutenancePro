{% extends 'base.html.twig' %}

{% block body %}
<div class="page-wrapper">

    <!-- Preloader -->
    <div class="preloader"></div>

    <!-- Main Header -->
    <header class="main-header">
        <div class="header-upper">
            <div class="outer-container">
                <div class="clearfix">

                    <div class="header-left clearfix">
                        <div class="left-sidebar-btn hidden-bar-opener">
                            <span class="icon flaticon-menu-2"></span>
                        </div>
                        <div class="pull-left logo-box">
                            <div class="logo">
                                <a href="{{ path('admin_dashboard') }}">
                                    <img src="{{ asset('logo/logo_horizontal.png') }}" alt="SoutenancePro" style="height:42px; margin-top:14px;">
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="header-right clearfix">
                        <div class="options-box clearfix">
                            <div class="profile-box dropdown" id="adminProfileBox">
                                <div class="btn btn-default dropdown-toggle" data-toggle="dropdown">
                                    <span class="profile-image" style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:#ff5773;color:#fff;font-weight:700;font-size:15px;vertical-align:middle;">
                                        {{ app.user ? app.user.email|first|upper : 'A' }}
                                    </span>
                                    <i class="arrow flaticon-down-arrow" style="margin-left:6px;"></i>
                                </div>
                                <div class="profile-content">
                                    <div class="setting" style="padding:10px 15px;font-weight:600;color:#0f0e2d;font-size:13px;border-bottom:1px solid #f0f0f0;">
                                        {{ app.user ? app.user.email : 'Admin' }}
                                    </div>
                                    <ul class="pages" style="margin:0;padding:5px 0;">
                                        <li><a href="{{ path('app_logout') }}"><i class="fa fa-sign-out" style="margin-right:6px;"></i>Déconnexion</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </header>
    <!-- End Main Header -->

    <!-- Page Content -->
    <div class="sidebar-page-container">
        <div class="auto-container">

            <!-- Page Title -->
            <div class="sec-title" style="margin-bottom:25px;">
                <div class="clearfix">
                    <div class="pull-left">
                        <h4 style="color:#0f0e2d;font-weight:700;">{% block page_title %}Administration{% endblock %}</h4>
                    </div>
                    <div class="pull-right">
                        {% block page_actions %}{% endblock %}
                    </div>
                </div>
            </div>

            <!-- Flash Messages -->
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert" style="border-radius:5px;margin-bottom:20px;">
                        <i class="fa fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}" style="margin-right:8px;"></i>
                        {{ message }}
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Content Block -->
            {% block content %}{% endblock %}

        </div>
    </div>
    <!-- End Page Content -->

</div>
<!-- End page-wrapper -->

<!-- Sidebar Nav (sidenav-list) -->
<div class="sidenav-list">
    <ul class="navbar">
        <li>
            <a href="{{ path('admin_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <i class="icon flaticon-home"></i>
                <span><i class="flaticon-home"></i> Tableau de bord</span>
            </a>
        </li>
        <li>
            <a href="{{ path('admin_etudiant_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_etudiant' ? 'active' : '' }}">
                <i class="icon flaticon-student"></i>
                <span><i class="flaticon-student"></i> Étudiants</span>
            </a>
        </li>
        <li>
            <a href="{{ path('admin_enseignant_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_enseignant' ? 'active' : '' }}">
                <i class="icon flaticon-instructor"></i>
                <span><i class="flaticon-instructor"></i> Enseignants</span>
            </a>
        </li>
        <li>
            <a href="{{ path('admin_salle_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_salle' ? 'active' : '' }}">
                <i class="icon flaticon-location"></i>
                <span><i class="flaticon-location"></i> Salles</span>
            </a>
        </li>
        <li>
            <a href="{{ path('admin_soutenance_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_soutenance' ? 'active' : '' }}">
                <i class="icon flaticon-schedule"></i>
                <span><i class="flaticon-schedule"></i> Soutenances</span>
            </a>
        </li>
        <li>
            <a href="{{ path('app_logout') }}">
                <i class="icon fa fa-sign-out"></i>
                <span><i class="fa fa-sign-out"></i> Déconnexion</span>
            </a>
        </li>
    </ul>
</div>
<!-- End Sidebar Nav -->

<!-- Hidden Navigation Bar -->
<section class="hidden-bar left-align">
    <div class="color-layer"></div>
    <div class="hidden-bar-closer">
        <span class="flaticon-multiply"></span>
    </div>
    <div class="hidden-bar-wrapper">
        <ul class="pages-list">
            <li class="{{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <a href="{{ path('admin_dashboard') }}">
                    <span class="icon flaticon-home"></span>Tableau de bord
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') starts with 'admin_etudiant' ? 'active' : '' }}">
                <a href="{{ path('admin_etudiant_index') }}">
                    <span class="icon flaticon-student"></span>Étudiants
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') starts with 'admin_enseignant' ? 'active' : '' }}">
                <a href="{{ path('admin_enseignant_index') }}">
                    <span class="icon flaticon-instructor"></span>Enseignants
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') starts with 'admin_salle' ? 'active' : '' }}">
                <a href="{{ path('admin_salle_index') }}">
                    <span class="icon flaticon-location"></span>Salles
                </a>
            </li>
            <li class="{{ app.request.attributes.get('_route') starts with 'admin_soutenance' ? 'active' : '' }}">
                <a href="{{ path('admin_soutenance_index') }}">
                    <span class="icon flaticon-schedule"></span>Soutenances
                </a>
            </li>
        </ul>
        <div class="heading">Compte</div>
        <ul class="pages-list">
            <li>
                <a href="{{ path('app_logout') }}">
                    <span class="icon fa fa-sign-out"></span>Déconnexion
                </a>
            </li>
        </ul>
    </div>
    <div class="copyright-text">&copy; {{ "now"|date("Y") }} SoutenancePro</div>
</section>
<!-- End Hidden Navigation Bar -->

{% block javascripts %}{{ parent() }}{% endblock %}
{% endblock %}
